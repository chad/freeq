// bug-hunt — find ONE real correctness bug in freeq, prove it with a failing
// test, fix it, and verify.
//
// hunt (opus, read-only): deeply audit one subsystem; identify a concrete,
//   real bug (not style/nits). If none found with confidence, say so.
// reproduce+fix: write a test that fails on the bug, then make the minimal fix.
// verify: authoritative CI-mirror gate (goal_gate).
// pr_body: explain the bug, the repro, and the fix.
digraph BugHunt {
    graph [goal="Find one genuine correctness bug in freeq's CI-covered code, pin it with a regression test that fails before the fix, fix it minimally, and verify. Quality over quantity — one real, well-proven bug, never a speculative or cosmetic change."]
    rankdir=LR

    start [shape=Mdiamond, label="Start"]
    exit  [shape=Msquare, label="Exit"]

    hunt      [shape=box, label="Hunt for a bug", prompt="@prompts/hunt.md", model="claude-opus-4-8", reasoning_effort="high", thread_id="bug", fidelity="full", timeout="2400s"]
    fix       [shape=box, label="Repro + fix",    prompt="@prompts/fix.md", thread_id="bug", fidelity="full", reasoning_effort="high", timeout="2400s"]
    verify    [shape=parallelogram, label="CI gate", script="bash .fabro/verify.sh", goal_gate=true, retry_target="fix", max_retries=2, timeout="3600s"]
    pr_body   [shape=tab, label="PR description", prompt="@prompts/pr_body.md", thread_id="bug", fidelity="full"]

    start -> hunt -> fix -> verify -> pr_body -> exit
}
