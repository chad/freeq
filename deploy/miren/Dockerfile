# freeq self-hosting image for Miren — IRC server + web client in one image.
#
# Built by deploy/miren/deploy.sh, which stages the workspace in a temp
# directory first (web client at web-client/, JS SDK at freeq-sdk-js/) and
# copies this file in as Dockerfile.miren.

# ── Rust build ──
FROM rust:1.89-slim AS builder
RUN apt-get update && apt-get install -y pkg-config libssl-dev && rm -rf /var/lib/apt/lists/*
WORKDIR /build
COPY Cargo.toml Cargo.lock ./
# Cargo must resolve every workspace member referenced by Cargo.toml even
# though only freeq-server is compiled. The deploy script copies whichever exist.
COPY freeq-sdk/ freeq-sdk/
COPY freeq-server/ freeq-server/
COPY freeq-tui/ freeq-tui/
COPY freeq-auth-broker/ freeq-auth-broker/
COPY freeq-bots/ freeq-bots/
COPY freeq-bot-id/ freeq-bot-id/
COPY freeq-sdk-ffi/ freeq-sdk-ffi/
COPY freeq-windows-core/ freeq-windows-core/
COPY freeq-av-client/ freeq-av-client/
RUN cargo build --release --package freeq-server

# ── Web client build ──
FROM node:20-slim AS web-builder
WORKDIR /build
# Build @freeq/sdk first — the web app depends on its compiled dist via
# `file:../freeq-sdk-js`.
COPY freeq-sdk-js/ ./freeq-sdk-js/
RUN cd freeq-sdk-js && npm ci --silent && npm run build
COPY web-client/package.json web-client/package-lock.json ./web-client/
RUN cd web-client && npm ci --ignore-scripts
COPY web-client/ ./web-client/
RUN cd web-client && npm run build

# ── Runtime ──
# Runtime base must match the builder's GLIBC — rust:1.89-slim is Debian
# trixie (GLIBC 2.41), so the binary can't run on bookworm (GLIBC 2.36):
# it crashes at startup with "GLIBC_2.38 not found".
FROM debian:trixie-slim
RUN apt-get update && apt-get install -y ca-certificates && rm -rf /var/lib/apt/lists/*
RUN mkdir -p /app/data /app/web
COPY --from=builder /build/target/release/freeq-server /app/freeq-server
COPY --from=web-builder /build/web-client/dist /app/web
WORKDIR /app
EXPOSE 8080
# The Procfile generated by deploy.sh is the real process definition; this
# CMD is only a fallback with generic defaults. Miren sets $PORT.
CMD /app/freeq-server \
  --listen-addr 127.0.0.1:16667 \
  --web-addr 0.0.0.0:${PORT:-8080} \
  --web-static-dir /app/web \
  --db-path /app/data/freeq.db \
  --data-dir /app/data
